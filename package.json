{
  "name": "neurotrack",
  "version": "1.0.0",
  "description": "AI Study Optimization System – full-stack MERN app",
  "scripts": {
    "dev": "concurrently --names \"server,client\" --prefix-colors \"green,blue\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "seed": "cd server && npm run seed",
    "build": "cd client && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
