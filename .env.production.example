# Production Environment Variables Template
# Replace with your actual values - DO NOT commit real credentials

NODE_ENV=production
PORT=5000

# Database - Replace with your NEW MongoDB URI after password change
MONGODB_URI=mongodb+srv://username:NEW_PASSWORD@cluster.mongodb.net/neurotrack

# JWT Secret - Generate a NEW secure random string
JWT_SECRET=generate_new_32_character_secret

# Frontend URL - Replace with your deployed frontend URL
CLIENT_URL=https://your-frontend-domain.com
